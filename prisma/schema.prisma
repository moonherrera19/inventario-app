generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Rol {
  id       Int       @id @default(autoincrement())
  nombre   String    @unique
  usuarios Usuario[]
}

model Usuario {
  id           Int                    @id @default(autoincrement())
  nombre       String
  correo       String                 @unique
  password     String
  rolId        Int
  creadoEn     DateTime               @default(now())
  comprasAdmin CompraAdministrativa[]
  rol          Rol                    @relation(fields: [rolId], references: [id])
}

model Categoria {
  id          Int        @id @default(autoincrement())
  nombre      String
  descripcion String?
  productos   Producto[]
}

model Proveedor {
  id                  Int                    @id @default(autoincrement())
  nombre              String
  telefono            String?
  direccion           String?
  banco               String?
  bancoDolares        String?
  clabe               String?
  clabeDolares        String?
  correo              String?
  numeroCuenta        String?
  numeroCuentaDolares String?
  rfc                 String?
  compras             Compra[]
  comprasAdmin        CompraAdministrativa[]
  productos           Producto[]
}

model Producto {
  id              Int              @id @default(autoincrement())
  nombre          String
  unidad          String
  stock           Float            @default(0)
  creadoEn        DateTime         @default(now())
  categoriaId     Int?
  actualizadoEn   DateTime         @updatedAt
  precioUnitario  Float?
  proveedorId     Int?
  stockMinimo     Float            @default(0)
  manejaLotes     Boolean          @default(false)
  compras         Compra[]
  consumos        Consumo[]
  entradas        Entrada[]
  ingredientes    Ingrediente[]
  inventarioLotes InventarioLote[]
  categoria       Categoria?       @relation(fields: [categoriaId], references: [id])
  proveedor       Proveedor?       @relation(fields: [proveedorId], references: [id])
  salidas         Salida[]
}

model CompraAdministrativa {
  id              Int           @id @default(autoincrement())
  proveedorId     Int
  usuarioId       Int?
  fechaFactura    DateTime?
  numeroFactura   String?
  concepto        String
  monto           Float
  estatus         EstatusCompra @default(CAPTURADA)
  fechaPago       DateTime?
  observaciones   String?
  creadoEn        DateTime      @default(now())
  actualizadoEn   DateTime      @updatedAt
  banco           String?
  cuentaClabe     String?
  empresa         String?
  moneda          String        @default("MXN")
  precio          Float?
  proveedorNombre String?
  proveedor       Proveedor     @relation(fields: [proveedorId], references: [id])
  usuario         Usuario?      @relation(fields: [usuarioId], references: [id])

  @@index([estatus])
  @@index([proveedorId])
}

model InventarioLote {
  id                 Int       @id @default(autoincrement())
  productoId         Int
  loteCodigo         String
  fechaCaducidad     DateTime?
  cantidadDisponible Float
  fechaEntrada       DateTime  @default(now())
  producto           Producto  @relation(fields: [productoId], references: [id])
  salidas            Salida[]

  @@index([productoId])
}

model Entrada {
  id         Int      @id @default(autoincrement())
  productoId Int
  cantidad   Float
  fecha      DateTime @default(now())
  producto   Producto @relation(fields: [productoId], references: [id])
}

model Salida {
  id               Int             @id @default(autoincrement())
  productoId       Int
  cantidad         Float
  fecha            DateTime        @default(now())
  cultivo          String?
  rancho           String?
  inventarioLoteId Int?
  inventarioLote   InventarioLote? @relation(fields: [inventarioLoteId], references: [id])
  producto         Producto        @relation(fields: [productoId], references: [id])
}

model Compra {
  id          Int       @id @default(autoincrement())
  productoId  Int
  costo       Float
  cantidad    Float
  fecha       DateTime  @default(now())
  proveedorId Int
  producto    Producto  @relation(fields: [productoId], references: [id])
  proveedor   Proveedor @relation(fields: [proveedorId], references: [id])
}

model Receta {
  id           Int           @id @default(autoincrement())
  nombre       String
  ingredientes Ingrediente[]
}

model Ingrediente {
  id         Int      @id @default(autoincrement())
  recetaId   Int
  productoId Int
  cantidad   Float
  producto   Producto @relation(fields: [productoId], references: [id])
  receta     Receta   @relation(fields: [recetaId], references: [id])
}

model Lote {
  id       Int       @id @default(autoincrement())
  nombre   String
  cultivo  String?
  areaHa   Float?
  consumos Consumo[]
}

model Consumo {
  id         Int      @id @default(autoincrement())
  loteId     Int
  productoId Int
  cantidad   Float
  fecha      DateTime @default(now())
  lote       Lote     @relation(fields: [loteId], references: [id])
  producto   Producto @relation(fields: [productoId], references: [id])
}

enum EstatusCompra {
  CAPTURADA
  APROBADA
  PAGADA
}
