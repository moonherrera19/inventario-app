// ========================================================
//   SCHEMA PRISMA — INVENTARIO AGRÍCOLA PROFESIONAL
// ========================================================

// ---- CONFIGURACIÓN ----
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ========================================================
// ROLES Y USUARIOS
// ========================================================

model Rol {
  id       Int       @id @default(autoincrement())
  nombre   String    @unique
  usuarios Usuario[]
}

model Usuario {
  id        Int    @id @default(autoincrement())
  nombre    String
  correo    String @unique
  password  String
  rolId     Int

  rol       Rol      @relation(fields: [rolId], references: [id])
  creadoEn  DateTime @default(now())

  comprasAdmin CompraAdministrativa[]
}

// ========================================================
// CATÁLOGOS
// ========================================================

model Categoria {
  id          Int        @id @default(autoincrement())
  nombre      String
  descripcion String?
  productos   Producto[]
}

model Proveedor {
  id        Int        @id @default(autoincrement())
  nombre    String
  telefono  String?
  direccion String?

  productos    Producto[]
  compras      Compra[]
  comprasAdmin CompraAdministrativa[]
}

// ========================================================
// PRODUCTOS DEL INVENTARIO
// ========================================================

model Producto {
  id             Int    @id @default(autoincrement())
  nombre         String
  unidad         String
  categoriaId    Int?
  proveedorId    Int?
  precioUnitario Float?
  stock          Float  @default(0)
  stockMinimo    Float  @default(0)

  categoria Categoria? @relation(fields: [categoriaId], references: [id])
  proveedor Proveedor? @relation(fields: [proveedorId], references: [id])

  entradas        Entrada[]
  salidas         Salida[]
  compras         Compra[]
  ingredientes    Ingrediente[]
  consumos        Consumo[]
  inventarioLotes InventarioLote[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
}

// ========================================================
// INVENTARIO POR LOTE (LOTE + CADUCIDAD)
// ========================================================

model InventarioLote {
  id                 Int       @id @default(autoincrement())
  productoId         Int
  loteCodigo         String
  fechaCaducidad     DateTime?
  cantidadDisponible Float
  fechaEntrada       DateTime  @default(now())

  producto Producto @relation(fields: [productoId], references: [id])
  salidas  Salida[]

  @@index([productoId])
}

// ========================================================
// MOVIMIENTOS DE INVENTARIO
// ========================================================

model Entrada {
  id         Int      @id @default(autoincrement())
  productoId Int
  cantidad   Float
  fecha      DateTime @default(now())

  producto Producto @relation(fields: [productoId], references: [id])
}

model Salida {
  id               Int      @id @default(autoincrement())
  productoId       Int
  inventarioLoteId Int?
  cantidad         Float
  fecha            DateTime @default(now())

  rancho  String?
  cultivo String?

  producto       Producto        @relation(fields: [productoId], references: [id])
  inventarioLote InventarioLote? @relation(fields: [inventarioLoteId], references: [id])
}

// ========================================================
// COMPRAS OPERATIVAS (AFECTAN INVENTARIO)
// ========================================================

model Compra {
  id          Int      @id @default(autoincrement())
  productoId  Int
  proveedorId Int
  costo       Float
  cantidad    Float
  fecha       DateTime @default(now())

  producto  Producto  @relation(fields: [productoId], references: [id])
  proveedor Proveedor @relation(fields: [proveedorId], references: [id])
}

// ========================================================
// COMPRAS ADMINISTRATIVAS (FACTURAS / EXCEL / ESTATUS)
// ========================================================

enum EstatusCompra {
  CAPTURADA
  APROBADA
  PAGADA
}

model CompraAdministrativa {
  id            Int           @id @default(autoincrement())

  // Relaciones
  proveedorId   Int
  usuarioId     Int?

  // Datos tipo Excel / Factura
  numeroFactura String?
  banco         String?
  cuentaClabe   String?
  empresa       String?
  moneda        String        @default("MXN")

  concepto      String
  precio        Float?
  monto         Float

  fechaFactura  DateTime?
  fechaPago     DateTime?

  // Control administrativo
  estatus       EstatusCompra @default(CAPTURADA)
  observaciones String?

  // Auditoría
  creadoEn      DateTime      @default(now())
  actualizadoEn DateTime      @updatedAt

  proveedor Proveedor @relation(fields: [proveedorId], references: [id])
  usuario   Usuario?  @relation(fields: [usuarioId], references: [id])

  @@index([estatus])
  @@index([proveedorId])
}

// ========================================================
// RECETAS — MEZCLAS AGRÍCOLAS / ALIMENTOS / FERTILIZANTES
// ========================================================

model Receta {
  id           Int           @id @default(autoincrement())
  nombre       String
  ingredientes Ingrediente[]
}

model Ingrediente {
  id         Int   @id @default(autoincrement())
  recetaId   Int
  productoId Int
  cantidad   Float

  receta   Receta   @relation(fields: [recetaId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id])
}

// ========================================================
// REGISTROS AGRÍCOLAS PROFESIONALES (LOTES DE CAMPO)
// ========================================================

model Lote {
  id      Int     @id @default(autoincrement())
  nombre  String
  cultivo String?
  areaHa  Float?

  consumos Consumo[]
}

model Consumo {
  id         Int      @id @default(autoincrement())
  loteId     Int
  productoId Int
  cantidad   Float
  fecha      DateTime @default(now())

  lote     Lote     @relation(fields: [loteId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id])
}
